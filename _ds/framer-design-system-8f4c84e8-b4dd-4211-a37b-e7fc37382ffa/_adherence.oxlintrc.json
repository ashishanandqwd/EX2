{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/cards/**",
              "components/data/**",
              "components/forms/**",
              "components/navigation/**",
              "components/pricing/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Mona Sans))/i]",
        "message": "Font not provided by the design system. Available: Inter, Mona Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|translucent)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'translucent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComparisonRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|values|header|style|key|ref|className|style|children)$/]",
        "message": "<ComparisonRow> doesn't accept that prop. Declared props: label, values, header, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FaqRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|answer|open|defaultOpen|onToggle|style|key|ref|className|style|children)$/]",
        "message": "<FaqRow> doesn't accept that prop. Declared props: question, answer, open, defaultOpen, onToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|links|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: heading, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|disabled|onClick|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, size, disabled, onClick, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|period|blurb|features|cta|ctaVariant|featured|onCta|style|key|ref|className|style|children)$/]",
        "message": "<PricingCard> doesn't accept that prop. Declared props: name, price, period, blurb, features, cta, ctaVariant, featured, onCta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingCard'] > JSXAttribute[name.name='ctaVariant'] > Literal[value!=/^(?:primary|secondary|translucent)$/]",
        "message": "<PricingCard> ctaVariant must be one of 'primary' | 'secondary' | 'translucent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<PricingTabs> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductMockupTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:url|title|children|style|key|ref|className|style|children)$/]",
        "message": "<ProductMockupTile> doesn't accept that prop. Declared props: url, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpotlightCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|eyebrow|title|children|footer|style|key|ref|className|style|children)$/]",
        "message": "<SpotlightCard> doesn't accept that prop. Declared props: variant, eyebrow, title, children, footer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpotlightCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:violet|magenta|orange|coral)$/]",
        "message": "<SpotlightCard> variant must be one of 'violet' | 'magenta' | 'orange' | 'coral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TemplateCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|meta|thumb|aspect|onClick|style|key|ref|className|style|children)$/]",
        "message": "<TemplateCard> doesn't accept that prop. Declared props: title, meta, thumb, aspect, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|type|disabled|prefix|suffix|style|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: value, onChange, placeholder, type, disabled, prefix, suffix, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|links|onSignIn|onGetStarted|style|key|ref|className|style|children)$/]",
        "message": "<TopNav> doesn't accept that prop. Declared props: brand, links, onSignIn, onGetStarted, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
